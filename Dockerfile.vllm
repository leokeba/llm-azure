ARG VLLM_BASE_IMAGE=vllm/vllm-openai:latest
FROM ${VLLM_BASE_IMAGE}

ARG MODEL_ID=mistralai/Ministral-3-8B-Instruct-2512
ARG SERVED_MODEL_NAME=ministral-8b
ARG VLLM_DTYPE=float16
ARG GPU_MEMORY_UTILIZATION=0.90
ARG MAX_MODEL_LEN=8192
ARG MAX_NUM_SEQS=24

ENV MODEL_ID=${MODEL_ID}
ENV SERVED_MODEL_NAME=${SERVED_MODEL_NAME}
ENV VLLM_DTYPE=${VLLM_DTYPE}
ENV GPU_MEMORY_UTILIZATION=${GPU_MEMORY_UTILIZATION}
ENV MAX_MODEL_LEN=${MAX_MODEL_LEN}
ENV MAX_NUM_SEQS=${MAX_NUM_SEQS}

CMD ["sh", "-lc", "python3 -m vllm.entrypoints.openai.api_server --host 0.0.0.0 --port 8000 --model \"$MODEL_ID\" --dtype \"$VLLM_DTYPE\" --gpu-memory-utilization \"$GPU_MEMORY_UTILIZATION\" --max-model-len \"$MAX_MODEL_LEN\" --max-num-seqs \"$MAX_NUM_SEQS\" --served-model-name \"$SERVED_MODEL_NAME\""]
