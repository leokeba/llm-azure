# vLLM runtime
VLLM_BASE_IMAGE=vllm/vllm-openai:latest
MODEL_ID=mistralai/Ministral-3-8B-Instruct-2512
SERVED_MODEL_NAME=ministral-8b
VLLM_PORT=8000
VLLM_BIND_IP=0.0.0.0
# Comma-separated list of CIDRs allowed to reach VLLM_PORT on the host firewall.
# Example: VLLM_ALLOWED_CIDRS=51.15.10.20/32,10.0.0.0/8
VLLM_ALLOWED_CIDRS=
VLLM_DTYPE=float16
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=24
# Max seconds deploy/redeploy waits for vLLM API readiness (/v1/models).
VLLM_READY_TIMEOUT_SEC=900
HF_CACHE_DIR=/data/models

# Optional: required if model access is gated on Hugging Face
HUGGING_FACE_HUB_TOKEN=

# Azure GPU VM deploy values
AZ_SUBSCRIPTION_ID=
AZ_RESOURCE_GROUP=rg-llm-azure
AZ_LOCATION=westeurope
AZ_VM_NAME=llm-ministral-vllm
AZ_VM_SIZE=Standard_NC4as_T4_v3
AZ_VM_IMAGE=Ubuntu2204
AZ_OS_DISK_SIZE_GB=80
AZ_ADMIN_USERNAME=ubuntu
# Set false only if you have private network access path to the VM.
AZ_ATTACH_PUBLIC_IP=true
# Optional static public IP SKU (Basic|Standard) when public IP is attached.
AZ_PUBLIC_IP_SKU=Standard
AZ_SSH_PUBLIC_KEY_PATH=$HOME/.ssh/id_rsa.pub
AZ_SSH_PRIVATE_KEY_PATH=
